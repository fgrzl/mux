# Auto detect text files and normalize line endings to LF
* text=auto

# Go source code
*.go text eol=lf

# Go module and sum files
go.mod text eol=lf
go.sum text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.a binary
*.o binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary

# IDE and build artifacts
.DS_Store binary
Thumbs.db binary
